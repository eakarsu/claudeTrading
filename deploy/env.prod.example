# Production .env for the Hostinger VPS. Copy this to `/opt/claude-trading/.env`
# on the VPS and fill in every secret. NEVER commit the populated file.

# ── Image ──
# Registry/tag built + pushed with `docker buildx build --push`.
IMAGE=docker.io/eakarsun4/claude-trading:latest

# ── Domain ──
# Must resolve via DNS (A record → 76.13.101.16) before you bring Caddy up,
# otherwise the ACME cert issuance will fail.
DOMAIN=luranai.site
CORS_ORIGIN=https://luranai.site

# ── Auth ──
# Generate with: openssl rand -hex 48
JWT_SECRET=
# Set to `false` in production once your account is seeded.
ALLOW_REGISTRATION=false

# ── Database ──
DB_USER=trading
DB_PASSWORD=
DB_NAME=trading

# ── Alpaca ──
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_TRADING=false

# ── AI / Email / Optional ──
ANTHROPIC_API_KEY=
RESEND_API_KEY=
RESEND_FROM=

# ── FreqAI Python sidecar (optional) ──
FREQAI_PY_URL=
FREQAI_PY_TOKEN=
